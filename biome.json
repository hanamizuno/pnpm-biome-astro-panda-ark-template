{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "lineWidth": 100,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/.claude",
      "!**/.astro",
      "!**/dist",
      "!**/coverage",
      "!**/node_modules",
      "!**/styled-system",
      "!**/styled-system-studio",
      "!**/pnpm-lock.yaml",
      "!**/public",
      "!**/*.astro"
    ]
  }
}
