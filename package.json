    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-external-links": "^3.0.0",
    "remark-breaks": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.0.0",
    "@pandacss/dev": "^1.10.0",
    "@pandacss/studio": "^1.10.0",
    "@secretlint/secretlint-rule-preset-recommend": "^8.0.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.0.0",
    "secretlint": "^8.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
