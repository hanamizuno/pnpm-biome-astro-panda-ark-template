{
  "name": "pnpm-biome-astro-panda-ark-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "studio": "panda studio --port 3000",
    "astro": "astro",
    "check": "astro check",
    "typecheck": "astro check",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "bench": "vitest bench",
    "release-check": "biome ci . && astro check && vitest run && astro build",
    "scan:secrets": "pnpm exec secretlint \"**/*\""
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.2",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
